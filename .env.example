# Vorlage für die .env – kopiere diese Datei nach ".env" und trage die echten
# Zugangsdaten ein. Die .env selbst gehört NICHT ins Git.
#
# Variante A (empfohlen): kompletter Connection-String wie in der server.cfg.
#   Format: mysql://USER:PASSWORT@HOST[:PORT]/DBNAME?charset=utf8mb4
MYSQL_CONNECTION_STRING='mysql://USER:PASSWORT@HOST/DBNAME?charset=utf8mb4'

# Variante B (alternativ): einzelne Felder. Wird nur genutzt, wenn oben nichts steht.
# MYSQL_HOST=de13.spaceify.eu
# MYSQL_PORT=3306
# MYSQL_USER=u44557_xxxxxxxx
# MYSQL_PASSWORD=geheim
# MYSQL_DATABASE=s44557_mysql
# MYSQL_CHARSET=utf8mb4
